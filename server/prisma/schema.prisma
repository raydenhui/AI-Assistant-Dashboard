// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model - stores user information and authentication tokens
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String?
  picture       String?
  
  // Google OAuth tokens (encrypted in production)
  googleAccessToken  String?
  googleRefreshToken String?
  googleTokenExpiry  DateTime?
  
  // LLM Provider settings
  llmProvider   LLMProvider @default(OPENROUTER)
  llmSettings   Json?       // Additional provider-specific settings
  openRouterKey String?     // User-specific OpenRouter API key
  
  // User preferences
  theme         Theme    @default(SYSTEM)
  timezone      String   @default("UTC")
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  conversations Conversation[]
  tasks         Task[]
  cachedEmails  CachedEmail[]
  cachedEvents  CachedEvent[]
  
  @@map("users")
}

// Conversation model - AI chat conversations
model Conversation {
  id        String   @id @default(uuid())
  userId    String
  title     String   @default("New Conversation")
  summary   String?  // AI-generated summary for context management
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  
  @@index([userId])
  @@map("conversations")
}

// Message model - individual messages in a conversation
model Message {
  id             String   @id @default(uuid())
  conversationId String
  
  role           MessageRole
  content        String
  
  // Function calling support
  toolCalls      Json?    // Array of tool calls made by AI
  toolResults    Json?    // Results from tool executions
  
  // Metadata
  tokens         Int?     // Token count for context management
  
  createdAt      DateTime @default(now())
  
  // Relations
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  @@index([conversationId])
  @@map("messages")
}

// Task model - user tasks and action items
model Task {
  id          String     @id @default(uuid())
  userId      String
  
  title       String
  description String?
  
  status      TaskStatus @default(PENDING)
  priority    Priority   @default(MEDIUM)
  
  dueDate     DateTime?
  completedAt DateTime?
  
  // Source tracking (where the task came from)
  source      String?    // 'email', 'calendar', 'chat', 'manual'
  sourceId    String?    // ID of the source item (email ID, event ID, etc.)
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  // Relations
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([status])
  @@index([dueDate])
  @@map("tasks")
}

// CachedEmail model - cached Gmail messages with AI analysis
model CachedEmail {
  id          String   @id @default(uuid())
  userId      String
  
  // Gmail identifiers
  gmailId     String   @unique
  threadId    String
  
  // Email content
  subject     String
  sender      String
  senderEmail String
  recipients  Json?    // Array of recipient emails
  snippet     String   // Short preview
  body        String?  // Full email body (HTML or plain text)
  bodyType    String   @default("text/plain")
  
  // Email metadata
  labelIds    Json?    // Gmail labels
  isRead      Boolean  @default(false)
  isStarred   Boolean  @default(false)
  hasAttachments Boolean @default(false)
  isDismissed Boolean @default(false)
  
  // AI Analysis results
  aiPriority  Priority?
  aiSummary   String?
  aiActionItems Json?  // Extracted action items
  aiCategories Json?   // AI-assigned categories/tags
  
  receivedAt  DateTime
  cachedAt    DateTime @default(now())
  analyzedAt  DateTime?
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([threadId])
  @@index([receivedAt])
  @@index([aiPriority])
  @@map("cached_emails")
}

// CachedEvent model - cached Google Calendar events with AI analysis
model CachedEvent {
  id          String   @id @default(uuid())
  userId      String
  
  // Calendar identifiers
  calendarId  String   @unique
  recurringEventId String?
  
  // Event details
  title       String
  description String?
  location    String?
  
  // Time information
  startTime   DateTime
  endTime     DateTime
  isAllDay    Boolean  @default(false)
  timezone    String?
  
  // Attendees and status
  attendees   Json?    // Array of attendee objects
  organizer   String?
  status      EventStatus @default(CONFIRMED)
  
  // Meeting details
  meetingLink String?  // Google Meet or other video call link
  
  // AI Analysis results
  aiSummary   String?
  aiPrepNotes String?  // Meeting preparation notes
  aiActionItems Json?  // Extracted action items from event
  
  cachedAt    DateTime @default(now())
  analyzedAt  DateTime?
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([startTime])
  @@map("cached_events")
}

// Enums
enum LLMProvider {
  OPENROUTER
  OLLAMA
}

enum Theme {
  LIGHT
  DARK
  SYSTEM
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum EventStatus {
  CONFIRMED
  TENTATIVE
  CANCELLED
}
